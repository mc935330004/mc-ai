<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.ai.agent.capability.mapper.BusinessSystemMapper">


    <select id="findBusinessSystemPageList" resultType="org.example.ai.agent.capability.entity.BusinessSystem">
        select * from ai_business_system
        <where>
            <if test="keyword != null and keyword != ''">
                and (system_name like CONCAT('%', #{keyword}, '%') or
                system_code like CONCAT('%', #{keyword}, '%'))
            </if>
            <if test="enabled != null">
                and enabled = #{enabled}
            </if>
        </where>
        order by id desc
    </select>
</mapper>