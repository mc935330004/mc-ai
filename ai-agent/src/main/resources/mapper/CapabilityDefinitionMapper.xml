<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.ai.agent.capability.mapper.CapabilityDefinitionMapper">

    <select id="pageCapabilities" resultType="org.example.ai.agent.capability.entity.CapabilityDefinition">
        select * from ai_capability_definition
        <where>
            <if test="keyword != null and keyword != ''">
               and (capability_name like CONCAT('%', #{keyword}, '%') or
                capability_code like CONCAT('%', #{keyword}, '%') or
                description like CONCAT('%', #{keyword}, '%'))
            </if>
            <if test="domain != null and domain != ''">
                and `domain` = #{domain}
            </if>
            <if test="enabled != null">
                and enabled = #{enabled}
            </if>
        </where>
        order by updated_at desc
    </select>
</mapper>