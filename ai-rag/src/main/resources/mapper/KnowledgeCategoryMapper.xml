<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.ai.agent.modules.knowledgebase.mapper.KnowledgeCategoryMapper">

    <select id="findKnowledgeCategoryPageList"
            resultType="org.example.ai.agent.modules.knowledgebase.entity.KnowledgeCategory">
        select * from knowledge_category
        <where>
            del_flag = 0
            <if test="keyword != null and keyword != ''">
                and (`name` like CONCAT('%', #{keyword}, '%') or
                 `code` like CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        order by sort_order asc
    </select>
</mapper>